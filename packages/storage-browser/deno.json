{
  "name": "@anabranch/storage-browser",
  "version": "0.1.2",
  "description": "Browser storage adapter using IndexedDB for @anabranch/storage",
  "exports": "./index.ts",
  "compilerOptions": {
    "lib": ["ESNext", "DOM"]
  },
  "publish": {
    "exclude": [
      "examples/",
      "build_npm.ts",
      "npm/"
    ]
  },
  "imports": {
    "@anabranch/anabranch": "jsr:@anabranch/anabranch@^0",
    "@anabranch/storage": "jsr:@anabranch/storage@^0",
    "@deno/dnt": "jsr:@deno/dnt@^0",
    "@std/assert": "jsr:@std/assert@^1",
    "fake-indexeddb": "npm:fake-indexeddb@^4"
  },
  "mappings": {
    "@anabranch/anabranch": {
      "name": "anabranch",
      "version": "^0"
    },
    "jsr:@anabranch/storage": {
      "name": "anabranch",
      "version": "^0"
    },
    "npm:fake-indexeddb@^4": {
      "name": "fake-indexeddb",
      "version": "^4"
    }
  }
}
