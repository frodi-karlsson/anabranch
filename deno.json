{
  "workspace": [
    "./packages/anabranch",
    "./packages/broken-link-checker",
    "./packages/fs",
    "./packages/web-client",
    "./packages/db",
    "./packages/db-postgres",
    "./packages/db-sqlite",
    "./packages/db-mysql",
    "./packages/queue",
    "./packages/queue-redis",
    "./packages/queue-rabbitmq",
    "./packages/storage",
    "./packages/storage-browser",
    "./packages/storage-s3",
    "./packages/storage-gcs"
  ],
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ],
      "include": [
        "no-unused-vars",
        "no-unused-parameters",
        "no-floating-promises",
        "require-await",
        "no-async-promise-executor",
        "no-base-to-string",
        "no-conditional-assignment",
        "no-debugger",
        "no-empty",
        "no-eval",
        "no-fallthrough",
        "no-new-wrappers",
        "no-octal",
        "no-regex-spaces",
        "no-self-assign",
        "no-sparse-arrays",
        "no-throw-literal",
        "no-unreachable",
        "no-unsafe-finally",
        "no-unused-expressions",
        "use-isnan",
        "ban-types",
        "no-namespace",
        "no-empty-interface"
      ]
    }
  },
  "tasks": {
    "check": "deno fmt --check && deno lint && deno test --allow-read --allow-write --allow-sys --allow-env --allow-net",
    "test:integration": "deno run -A ./scripts/test-integration.ts",
    "doc": "deno run -A ./scripts/build-docs.ts",
    "doc:lint": "deno doc --lint ./packages/anabranch/index.ts",
    "coverage": "deno test --allow-read --allow-write --allow-sys --allow-env --allow-net --coverage=packages/anabranch/coverage --clean && deno coverage ./packages/anabranch/coverage",
    "coverage:html": "deno test --allow-read --allow-write --allow-sys --allow-env --allow-net --coverage=packages/anabranch/coverage --clean && deno coverage --html ./packages/anabranch/coverage",
    "coverage:lcov": "deno test --allow-read --allow-write --allow-sys --allow-env --allow-net --coverage=packages/anabranch/coverage --clean && deno coverage --lcov --output=packages/anabranch/coverage.lcov ./packages/anabranch/coverage",
    "build:npm": "deno run -A ./scripts/build-npm.ts"
  },
  "imports": {
    "ioredis": "npm:ioredis@^5.10.0"
  }
}
